# Copy to .env locally. In Docker/App Runner set these as runtime environment variables.

POSTGRESQL_DB_HOST=db.example.supabase.co
POSTGRESQL_DB_PORT=5432
POSTGRESQL_DB_NAME=postgres
POSTGRESQL_DB_USER=postgres
POSTGRESQL_DB_PASSWORD=your-password
POSTGRESQL_SSL_MODE=require

# Optional single URL (overrides POSTGRESQL_DB_* when set)
# DATABASE_URL=postgresql://postgres:your-password@db.example.supabase.co:5432/postgres

JWT_SECRET=change-me
MONGO_URI=mongodb://localhost:27017
